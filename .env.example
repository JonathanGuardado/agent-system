# Copy this file to .env and replace placeholder values before running
# the local smoke checks or starting the runtime.
#
# Local prerequisites:
# - gh CLI installed and authenticated (`gh auth status` must succeed)
# - repo contracts present under AGENT_SYSTEM_REPO_CONFIG_PATH

# Slack Socket Mode
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token
AGENT_SYSTEM_INTAKE_CHANNEL=C0123456789
AGENT_SYSTEM_EXECUTION_APPROVAL_CHANNEL=C0123456789

# Jira Cloud
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_USER_EMAIL=you@example.com
JIRA_API_KEY=your-jira-api-token
JIRA_TIMEOUT_SECONDS=30
AGENT_SYSTEM_JIRA_TARGET_PROJECTS=AGENT

# Jira custom field map
JIRA_FIELD_AGENT_ASSIGNED_COMPONENT=customfield_10001
JIRA_FIELD_AGENT_RETRY_COUNT=customfield_10002
JIRA_FIELD_AGENT_CAPABILITIES_NEEDED=customfield_10003
JIRA_FIELD_REPOSITORY=customfield_10004
JIRA_FIELD_REPO_PATH=customfield_10005
JIRA_FIELD_SLACK_THREAD_TS=customfield_10006
JIRA_FIELD_SLACK_CHANNEL=customfield_10007
JIRA_FIELD_MAX_ATTEMPTS=customfield_10008
# Set when the Jira project still uses a custom Epic Link field.
JIRA_FIELD_EPIC_LINK=customfield_10009

# Model providers
DEEPSEEK_API_KEY=your-deepseek-api-key
GEMINI_API_KEY=your-gemini-api-key

# Local runtime options
AGENT_SYSTEM_REPO_CONFIG_PATH=config/repos
AGENT_SYSTEM_DATA_DIR=.agent-system-data
AGENT_SYSTEM_COMPONENT_ID=agent-system-local
AGENT_SYSTEM_POLL_INTERVAL_SECONDS=30
AGENT_SYSTEM_MAX_BACKOFF_SECONDS=300
AGENT_SYSTEM_HEARTBEAT_INTERVAL_SECONDS=600
AGENT_SYSTEM_INTAKE_MODEL_TIMEOUT_SECONDS=10
AGENT_SYSTEM_RECONCILE_INTERVAL_SECONDS=300
AGENT_SYSTEM_PULL_REQUEST_BASE_BRANCH=main
AGENT_SYSTEM_EXECUTION_MODE=dry_run
AGENT_SYSTEM_EXECUTION_APPROVAL_POLICY=auto
